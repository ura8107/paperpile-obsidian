# Required
OBSIDIAN_VAULT_PATH=/Users/mtsr95/path/to/your/obsidian/vault

# Google Drive OAuth2
# Get these from Google Cloud Console: https://console.cloud.google.com
# Enable the Google Drive API, create OAuth2 credentials (Desktop app type)
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...

# Paperpile Google Drive locations
# DRIVE_PAPERPILE_FOLDER_ID: open Paperpile settings → Google Drive sync,
#   find the folder in Drive and copy the ID from the URL
# DRIVE_BIB_FILE_ID: open paperpile.bib in Drive, copy ID from URL
DRIVE_PAPERPILE_FOLDER_ID=1abc...
DRIVE_BIB_FILE_ID=1def...

# Optional overrides (these have defaults in config/defaults.json)
# POLL_INTERVAL_MS=900000
# REGISTRY_PATH=~/.paperpile-obsidian/processed.json
# OBSIDIAN_PAPERS_FOLDER=Papers
# PDF_TEMP_DIR=/tmp/paperpile-obsidian
